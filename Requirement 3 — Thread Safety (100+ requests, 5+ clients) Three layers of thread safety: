// Layer 1: each algorithm has its OWN mutex
class FixedWindow {
    std::mutex mtx_;   // only locks THIS client's fixed window
    Decision check() {
        std::lock_guard<std::mutex> lk(mtx_);  // auto lock/unlock
        // ...
    }
};

// Layer 2: global registry has its own mutex
class RateLimiter {
    mutable std::mutex registry_mtx_;   // protects the map
    std::unordered_map<std::string, ClientLimiter*> limiters_;

    RequestResult process(const std::string& cid, ...) {
        {
            std::lock_guard<std::mutex> lk(registry_mtx_);
            // find or create client entry
            lim = limiters_[cid];
        }
        // registry lock RELEASED here
        // different clients now run fully in parallel
        d = lim->fixed.check();
    }
};

// Layer 3: stats use atomic (lock-free, fastest)
struct ClientStats {
    std::atomic<long> total{0};
    std::atomic<long> allowed{0};
    std::atomic<long> rejected{0};
};

