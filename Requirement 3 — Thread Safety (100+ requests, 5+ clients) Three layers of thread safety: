void run_test_harness(RateLimiter& rl) {
    // 5 threads firing simultaneously
    for (int c = 0; c < 5; ++c) {
        threads.emplace_back([&, cid, c]() {
            for (int i = 0; i < 30; ++i) {   // 30 requests each
                auto res = rl.process(cid, algo);  // concurrent!
                // random sleep to create real contention
                std::this_thread::sleep_for(
                    std::chrono::milliseconds(rng() % 10));
            }
        });
    }
    // wait for ALL threads to finish
    for (auto& t : threads) t.join();
}
